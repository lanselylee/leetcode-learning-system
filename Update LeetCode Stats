name: Update LeetCode Stats

on:
  schedule:
    - cron: "0 */6 * * *"   # every 6 hours
  workflow_dispatch:

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Fetch LeetCode Stats
        run: |
          curl -s https://leetcode.com/graphql \
          -H "Content-Type: application/json" \
          --data '{"query":"{ matchedUser(username: \"xiaomeng\") { submitStats { acSubmissionNum { difficulty count } } } }"}' \
          > stats.json

      - name: Update README
        run: |
          EASY=$(jq '.data.matchedUser.submitStats.acSubmissionNum[] | select(.difficulty=="Easy") | .count' stats.json)
          MED=$(jq '.data.matchedUser.submitStats.acSubmissionNum[] | select(.difficulty=="Medium") | .count' stats.json)
          HARD=$(jq '.data.matchedUser.submitStats.acSubmissionNum[] | select(.difficulty=="Hard") | .count' stats.json)
          TOTAL=$(jq '.data.matchedUser.submitStats.acSubmissionNum[] | select(.difficulty=="All") | .count' stats.json)

          sed -i "s/{{EASY}}/$EASY/g" README.md
          sed -i "s/{{MED}}/$MED/g" README.md
          sed -i "s/{{HARD}}/$HARD/g" README.md
          sed -i "s/{{TOTAL}}/$TOTAL/g" README.md

      - name: Commit changes
        run: |
          git config --global user.name "leetcode-bot"
          git config --global user.email "leetcode-bot@users.noreply.github.com"
          git commit -am "Update LeetCode stats" || exit 0
          git push
